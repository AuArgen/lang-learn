# Долбоордун Docker аталышы жана иштөөчү порту
PROJECT_NAME=bilimai_learn_lang
PORT=3000

# Долбоордун негизги URL дареги (Мисалы: http://localhost:3000 же https://домен.кж)
APP_URL=http://localhost:3000

# Тышкы аутентификация жана маалыматтарды текшерүү кызматтарынын даректери
AUTH_SERVICE_URL=https://api.bilimai.kg/auth/google/login?redirect_url=http://localhost:8089/api/auth/success
EXTERNAL_CHECK_USER_URL=https://api.bilimai.kg/api/external/check-user
EXTERNAL_API_KEY=6YTJdQWfkPTuBLm3u42qjuVZ9WF3f3gd3fdgdfg3gdfgsfsdf

# Жеке JWT токендерди түзүү жана текшерүү үчүн купуя ачкыч (Secret)
JWT_SECRET=your_super_secret_jwt_key_here

DATABASE_URL="file:./dev.db"